# Copy this file to .env and fill in your values.
# The actual .env file is gitignored and must never be committed.

# ── Database ─────────────────────────────────────────────────────────────────
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=3306
DB_NAME=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Optional overrides ────────────────────────────────────────────────────────
# Set USE_DB=0 to skip the database entirely (for local dev without MySQL).
# USE_DB=1

# Override the Claude model used for profile generation.
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
